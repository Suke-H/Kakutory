---
import Header from '../components/Header.astro';

interface Props {
  title?: string;
}
const { title = 'kakutory' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/maton.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta property="og:title" content="kakutory" />
  <meta property="og:description" content="かくひと(@kaku_suke_33)のものづくりポートフォリオサイト。日々生産ライン稼働中" />
  <meta property="og:url" content="https://kakutory.com/" />
  <meta property="og:image" content="https://kakutory.com/kakutory_ogp.png" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Kakutory" />
  <script src="https://embed.zenn.studio/js/listen-embed-event.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <style is:global>
    :root {
      font-family: Inter, system-ui, Avenir, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      font-weight: 400;
      color: #213547;
      background-color: #E9E9E9;
    }
    body {
      margin: 0;
      background-color: #E9E9E9;
    }
    a {
      color: inherit;
      text-decoration: none;
    }
    #root {
      margin: 0 auto;
      background-color: #E9E9E9;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <footer class="footer">
    <p class="copywrite">© 2023 かくひと</p>
  </footer>
</body>
</html>

<style>
  .footer {
    position: relative;
    bottom: 0;
    width: 100%;
    margin: 10vh 0 0 0;
    height: 40px;
    background-color: #585858;
    display: flex;
    align-items: center;
  }
  .copywrite {
    color: #E0E0E0;
    position: absolute;
    right: 200px;
  }
</style>
