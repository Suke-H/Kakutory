---
import BaseLayout from './BaseLayout.astro';
import { Heading } from '../../src/components/Heading';
import { Profile } from '../../src/components/contents/Profile';
const { frontmatter } = Astro.props;
---
<BaseLayout title="About | kakutory">
  <div style="color: #585858; font-weight: bold; text-align: center;">
    <Heading text="ABOUT" client:only="react" />
  </div>
  <Profile client:only="react" />
  <div class="znc">
    <slot />
  </div>
</BaseLayout>

<style is:global>
  @import "zenn-content-css";
  .znc {
    width: 70%;
    margin: 0 auto;
    max-width: 800px;
  }
  @media (max-width: 600px) {
    .znc { width: 90%; }
  }
</style>
