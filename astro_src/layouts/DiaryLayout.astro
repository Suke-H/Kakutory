---
import BaseLayout from './BaseLayout.astro';
import { Heading } from '../../src/components/Heading';
const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
  <div style="color: #585858; font-weight: bold; text-align: center;">
    <Heading text="DIARY" client:only="react" />
  </div>

  <div class="znc">
    <slot />
  </div>

  <!-- Zenn埋め込みスクリプト -->
  <script src="https://embed.zenn.studio/js/listen-embed-event.js" type="module"></script>
  <script type="module">
    import('zenn-embed-elements');
  </script>
</BaseLayout>

<style is:global>
  @import "zenn-content-css";

  .znc {
    width: 70%;
    margin: 0 auto;
    max-width: 800px;
  }

  @media (max-width: 600px) {
    .znc { width: 90%; }
  }
</style>